generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  ADMIN_GENERAL
  ADMIN_ASOCIACION
  BASICO
}

enum EstadoRegistro {
  PENDIENTE_APROBACION
  APROBADO
  RECHAZADO
}

enum Disciplina {
  KENDO
  IAIDO
  JODO
}

enum Sexo {
  MASCULINO
  FEMENINO
  X
}

enum Graduacion {
  SIN_GRADUACION
  KYU_3
  KYU_2
  KYU_1
  DAN_1
  DAN_2
  DAN_3
  DAN_4
  DAN_5
  DAN_6
  DAN_7
  DAN_8
}

enum EstadoSolicitud {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum Provincia {
  BUENOS_AIRES
  CABA
  CATAMARCA
  CHACO
  CHUBUT
  CORDOBA
  CORRIENTES
  ENTRE_RIOS
  FORMOSA
  JUJUY
  LA_PAMPA
  LA_RIOJA
  MENDOZA
  MISIONES
  NEUQUEN
  RIO_NEGRO
  SALTA
  SAN_JUAN
  SAN_LUIS
  SANTA_CRUZ
  SANTA_FE
  SANTIAGO_DEL_ESTERO
  TIERRA_DEL_FUEGO
  TUCUMAN
}

model AdminGeneral {
  id       Int    @id @default(autoincrement())
  dni      String @unique
  password String
}

model Asociacion {
  id        Int       @id @default(autoincrement())
  nombre    String
  deleted_at DateTime?
  dojos     Dojo[]
  usuarios  Usuario[]
}

model Dojo {
  id            Int        @id @default(autoincrement())
  nombre        String
  asociacion_id Int
  deleted_at    DateTime?
  asociacion    Asociacion @relation(fields: [asociacion_id], references: [id])
  usuarios      Usuario[]
}

model Usuario {
  id                Int       @id @default(autoincrement())
  email             String    @unique
  password          String
  nombre            String
  apellido          String
  dni               String    @unique
  fecha_nacimiento  DateTime
  sexo              Sexo
  
  // Dirección
  calle_altura      String
  piso_depto        String?
  ciudad            String
  provincia         Provincia
  codigo_postal     String

  rol               Rol       @default(BASICO)
  estado_pago       Boolean   @default(false)
  
  asociacion_id     Int
  asociacion        Asociacion @relation(fields: [asociacion_id], references: [id])
  dojo_id           Int
  dojo              Dojo      @relation(fields: [dojo_id], references: [id])
  
  estado_reg        EstadoRegistro @default(PENDIENTE_APROBACION)
  estado_blanqueo   EstadoSolicitud @default(APROBADO)
  
  grad_kendo        Graduacion @default(SIN_GRADUACION)
  f_grad_kendo      DateTime?
  grad_iaido        Graduacion @default(SIN_GRADUACION)
  f_grad_iaido      DateTime?
  grad_jodo         Graduacion @default(SIN_GRADUACION)
  f_grad_jodo       DateTime?

  certificados      CertificadoExterno[]
  inscripciones     InscripcionEvento[]
  historial_grad    HistorialGraduacion[]
}

model CertificadoExterno {
  id              Int       @id @default(autoincrement())
  usuario_id      Int
  usuario         Usuario   @relation(fields: [usuario_id], references: [id])
  url_archivo     String
  disciplina      Disciplina
  grad_solicitada Graduacion
  estado          EstadoSolicitud @default(PENDIENTE)
}

model Evento {
  id              Int       @id @default(autoincrement())
  tipo            String 
  fecha_inicio    DateTime
  fecha_fin       DateTime
  datos_lugar     Json
  publicado       Boolean   @default(false)
  torneo          Torneo?
  examen          Examen?
  seminario       Seminario?
  inscripciones   InscripcionEvento[]
}

model Torneo {
  id                  Int      @id @default(autoincrement())
  evento_id           Int      @unique
  evento              Evento   @relation(fields: [evento_id], references: [id], onDelete: Cascade)
  disciplina          String
  costo_inscripcion   Float    @default(0)
  categorias          Json
  inscripcion_multiple Boolean @default(false)
  grad_min            String?
  grad_max            String?
  info_adicional      String?
}

model Examen {
  id                    Int      @id @default(autoincrement())
  evento_id             Int      @unique
  evento                Evento   @relation(fields: [evento_id], references: [id], onDelete: Cascade)
  disciplinas           Json
  graduaciones_a_rendir Json
  info_adicional        String?
}

model Seminario {
  id                Int      @id @default(autoincrement())
  evento_id         Int      @unique
  evento            Evento   @relation(fields: [evento_id], references: [id], onDelete: Cascade)
  disciplina        String
  costo_inscripcion Float    @default(0)
  info_adicional    String?
}

model InscripcionEvento {
  id              Int       @id @default(autoincrement())
  usuario_id      Int
  usuario         Usuario   @relation(fields: [usuario_id], references: [id])
  evento_id       Int
  evento          Evento    @relation(fields: [evento_id], references: [id])
  categoria_grad  Json
  disciplinas     Json?
  estado_aprob    EstadoSolicitud @default(PENDIENTE)
  pagado          Boolean   @default(false)
}

model HistorialGraduacion {
  id              Int       @id @default(autoincrement())
  usuario_id      Int
  usuario         Usuario   @relation(fields: [usuario_id], references: [id])
  disciplina      Disciplina
  graduacion      Graduacion
  fecha_obtencion DateTime
  otorgado_por    String
}

model PrecioExamen {
  id         Int      @id @default(autoincrement())
  graduacion String   @unique
  costo      Float
  updatedAt  DateTime @updatedAt

  @@map("precioexamen")
}

model CuotaGlobal {
  id                Int       @id @default(autoincrement())
  monto_actual      Float
  fecha_vencimiento DateTime

  @@map("cuotaglobal")
}
