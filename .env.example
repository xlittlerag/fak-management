# Base de datos
DATABASE_URL=file:./dev.db

# JWT
JWT_SECRET=change-this-to-a-secure-random-string

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxx-xxxxxx-xxxxxxxxxxxx-xxxxxxxx

# URL de la aplicación (para webhooks y redirecciones)
APP_URL=http://localhost:3000

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000

# SMTP (notificaciones por email - opcional, sin esto no se envían emails)
# Para Gmail: activar 2FA y generar App Password en https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=su-email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM="Kendo Manager <noreply@kendo-manager.com.ar>"
